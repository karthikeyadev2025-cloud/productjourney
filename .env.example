# Required — set these as Vercel Environment Variables.
# The server refuses to start if SUPERADMIN_EMAIL / SUPERADMIN_PASSWORD are
# missing — there is no built-in default login. Pick your own values below,
# do not reuse these placeholders.

SUPERADMIN_EMAIL=you@yourdomain.com
SUPERADMIN_PASSWORD=choose-a-long-random-password-here

# Optional but recommended — a separate secret used only to sign session
# tokens. If unset, one is derived from SUPERADMIN_PASSWORD instead (still
# safe, but a dedicated secret is stronger since it doesn't need to change
# whenever you rotate the admin password). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Gemini (Google AI Studio)
GEMINI_API_KEY=

# Supabase — get from your project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional (defaults to 4400 for local dev)
PORT=4400
